# Copy this file to .env in this folder (ready_atomo-forge-suite).
# The auth server loads .env before starting — restart `node auth-server.cjs` (or npm run dev) after changes.
# If meshcentral-data/config.json is not found automatically, set:
# MESHCENTRAL_CONFIG_PATH=/absolute/path/to/meshcentral-data/config.json

# --- Login page “Create account” link (optional; overrides API below) ---
# Must match how you open MeshCentral in the browser (http vs https matters).
# VITE_MESHCENTRAL_URL=http://192.168.1.111:3343
# VITE_MESHCENTRAL_URL=https://192.168.1.111:3343

# --- MeshCentral URLs (optional if meshcentral-data/config.json is found one level up) ---
# Use the same host:port as the MeshCentral browser UI (often same as settings.port in config.json):
# MESHCENTRAL_CONTROL_URL=wss://192.168.1.111:3343/control.ashx
# MESHCENTRAL_AGENT_BASE_URL=https://192.168.1.111:3343

# Optional: POST /api/meshcentral/run-agent (Run button) — disable or extend timeout (ms, default 600000)
# MESHCENTRAL_DISABLE_RUN_AGENT=true
# MESHCENTRAL_RUN_AGENT_TIMEOUT_MS=600000

# --- MeshCentral WEB login (same username/password as the browser UI) ---
# Optional: if unset, the auth server reuses settings.mysql from meshcentral-data/config.json
# (same file MeshCentral uses). Set MESHCENTRAL_USE_MYSQL_PROVISION=false to force .env only.
# This is NOT the same role as MYSQL_* below unless your web password matches the DB user password.
MESHCENTRAL_PROVISION_USER=atomo
MESHCENTRAL_PROVISION_PASS=your_meshcentral_web_password_here

# --- Universal Model Detection Dashboard (models + inference + websocket streaming) ---
# Example:
# VITE_UNIVERSAL_MODEL_DASHBOARD_URL=http://localhost:8080
# VITE_UNIVERSAL_MODEL_DASHBOARD_URL=http://192.168.1.50:8080

# --- MySQL (MeshCentral DB; used by auth-server) ---
# EC2 common case: MySQL listens on 127.0.0.1 ON THE SERVER ONLY — not reachable as 65.x.x.x:3306 from your laptop.
# From laptop: SSH tunnel then MYSQL_HOST=127.0.0.1 MYSQL_PORT=3307 (see npm run mysql:tunnel).
# On the EC2 box (auth-server runs there): MYSQL_HOST=127.0.0.1 MYSQL_PORT=3306
# MYSQL_CONNECT_TIMEOUT_MS=20000
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=atomo
MYSQL_PASSWORD=atomo@1234
MYSQL_DATABASE=meshcentral

# --- Detection events ONLY (atomo_forge) — no MeshCentral required ---
# Grant on MySQL host: scripts/sql/grant-atomo-forge.sql
# Then: npm run mysql:tunnel  +  npm run migrate:events
MYSQL_EVENTS_DATABASE=atomo_forge
# MYSQL_EVENTS_USER=atomo
# MYSQL_EVENTS_PASSWORD=atomo@1234

# Skip Caddy on :443 during npm run dev (use https://electron.local:8443 only):
# FORGE_SKIP_CADDY=1
#
# One-time (no port in URL): npm run caddy:start  — then npm run dev opens https://electron.local

# SPA → auth-server URL when NOT using Vite dev proxy (Electron packaged UI, file preview, etc.).
# Also used for GET /universal/api/models (see universalModelDashboard.ts).
# Example: VITE_AUTH_API_ORIGIN=http://127.0.0.1:3003
# Force models (and /api) via electron.local when the UI is not on that host:
# VITE_AUTH_API_ORIGIN=https://electron.local:8443
# Note: If the UI is served over https:// (e.g. electron.local), forcing http://127.0.0.1:3003 may be blocked as mixed content — prefer running the UI via `npm run dev` so /api is proxied on the same origin.
# Leave unset for `npm run dev` opened at https://electron.local:8443 (Vite proxies /api and /universal to AUTH_PORT).
# `vite preview` uses the same proxy (see vite.config preview); optional port override:
# VITE_PREVIEW_PORT=4173

# Device registration from the Forge UI is written to table `atomo_registered_devices`
# in THIS schema (not MeshCentral's `main` table). In Workbench: select schema
# meshcentral, refresh tables, open atomo_registered_devices or view
# v_atomo_device_registrations (created by migration 005).

# --- PDEU digital twin (optional; default HTTP port 3000 — set if busy; WS paths are /ws-fire and /ws-person on same port) ---
# TWIN_HTTP_PORT=3010
# Skip twin npm install in CI: SKIP_PDEU_TWIN_INSTALL=1
# Skip MediaMTX when `npm run dev` (no camera / port 8889 in use): FORGE_SKIP_MEDIAMTX=1
# Fire/person on digital twin: combine.py → detection_live.json (default, no MQTT)
# DETECTION_SOURCE=json
# DETECTION_CAMERA_LABELS=CAM1,CAM2
# Skip combine.py in dev (laptop without NPU): FORGE_SKIP_COMBINE_DETECTOR=1
# Skip NPU face_detector.py on laptop (needs `asnn` + mobilefacenet.onnx on the board): FORGE_SKIP_FACE_DETECTOR=1
# On the edge device: copy combine_detector.args.example → combine_detector.args in the twin folder
# Manual: npm run twin:install  (also runs after root npm install via postinstall)
