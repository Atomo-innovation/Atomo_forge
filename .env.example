# Copy this file to .env in this folder (ready_atomo-forge-suite).
# The auth server loads .env before starting — restart `node auth-server.cjs` (or npm run dev) after changes.
# If meshcentral-data/config.json is not found automatically, set:
# MESHCENTRAL_CONFIG_PATH=/absolute/path/to/meshcentral-data/config.json

# --- Login page “Create account” link (optional; overrides API below) ---
# Must match how you open MeshCentral in the browser (http vs https matters).
# VITE_MESHCENTRAL_URL=http://192.168.1.111:3343
# VITE_MESHCENTRAL_URL=https://192.168.1.111:3343

# --- MeshCentral URLs (optional if meshcentral-data/config.json is found one level up) ---
# Use the same host:port as the MeshCentral browser UI (often same as settings.port in config.json):
# MESHCENTRAL_CONTROL_URL=wss://192.168.1.111:3343/control.ashx
# MESHCENTRAL_AGENT_BASE_URL=https://192.168.1.111:3343

# Optional: POST /api/meshcentral/run-agent (Run button) — disable or extend timeout (ms, default 600000)
# MESHCENTRAL_DISABLE_RUN_AGENT=true
# MESHCENTRAL_RUN_AGENT_TIMEOUT_MS=600000

# --- MeshCentral WEB login (same username/password as the browser UI) ---
# Optional: if unset, the auth server reuses settings.mysql from meshcentral-data/config.json
# (same file MeshCentral uses). Set MESHCENTRAL_USE_MYSQL_PROVISION=false to force .env only.
# This is NOT the same role as MYSQL_* below unless your web password matches the DB user password.
MESHCENTRAL_PROVISION_USER=atomo
MESHCENTRAL_PROVISION_PASS=your_meshcentral_web_password_here

# --- Universal Model Detection Dashboard (models + inference + websocket streaming) ---
# Example:
# VITE_UNIVERSAL_MODEL_DASHBOARD_URL=http://localhost:8080
# VITE_UNIVERSAL_MODEL_DASHBOARD_URL=http://192.168.1.50:8080

# --- MySQL (database server only; used by auth-server login + device registration) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=atomo
MYSQL_PASSWORD=atomo@1234
MYSQL_DATABASE=meshcentral
