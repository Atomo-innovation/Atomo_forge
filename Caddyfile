{
	# Dev Vite is plain HTTP on :8443 (FORGE_VITE_PLAIN_HTTP=1). Keep http:// on :80.
	auto_https off
}

(vite_upstream) {
	reverse_proxy http://127.0.0.1:8443
}

# LAN: bind all interfaces so other devices can open http://electron.local (port 80).
# This laptop: optional 127.0.0.1 electron.local in /etc/hosts; phones use mDNS (npm run lan:setup).
http://electron.local, http://:80 {
	bind 0.0.0.0
	import vite_upstream
}
